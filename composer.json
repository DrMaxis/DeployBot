{
    "name": "afria/deploybot",
    "description": "Reusable Slack + Discord bot library for Afria products. Provides HMAC signature verification, a pluggable slash-command dispatcher, Block Kit helpers, Slack API + Discord webhook clients, and channel-subscription plumbing as a Laravel-installable composer package.",
    "type": "library",
    "license": "proprietary",
    "keywords": ["afria", "slack", "discord", "deploybot", "laravel"],
    "authors": [
        {
            "name": "Afria Technologies",
            "email": "engineering@alverium.net"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.9",
        "illuminate/bus": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Afria\\Deploybot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Afria\\Deploybot\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Afria\\Deploybot\\DeploybotServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "analyze": "phpstan analyze",
        "format": "pint",
        "check": "pint --test"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
